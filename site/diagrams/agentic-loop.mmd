flowchart TD
  REQ["request"] --> GUARDS["round-entry guards<br/>round / time / session / cost"]
  GUARDS --> CTX["context-overflow check<br/>compact or prune"]
  CTX --> LLM["call_llm(messages, tools)"]
  LLM --> DEC{"stop_reason ==<br/>tool_use ?"}
  DEC -->|yes| TOOLS["run tool calls<br/>append msg + tool_results"]
  TOOLS --> GUARDS
  DEC -->|no| ANSWER["answer<br/>natural / forced_text"]
  GUARDS -->|budget exhausted| TERM
  CTX -->|still critical| TERM
  LLM -->|refusal| TERM
  TERM["early termination<br/>max_rounds / time_budget_expired /<br/>cost_budget_exceeded /<br/>context_exhausted / model_refusal"]
