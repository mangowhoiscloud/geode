{
  "brave-search": {
    "command": "npx",
    "args": ["-y", "@brave/brave-search-mcp-server"],
    "env": {
      "BRAVE_API_KEY": "${BRAVE_API_KEY}"
    }
  },
  "steam": {
    "command": "npx",
    "args": ["-y", "steam-mcp-server"]
  },
  "arxiv": {
    "command": "npx",
    "args": ["-y", "@fre4x/arxiv"]
  },
  "playwright": {
    "command": "npx",
    "args": ["-y", "@playwright/mcp"]
  },
  "linkedin": {
    "command": "npx",
    "args": ["-y", "linkedin-mcp-runner"]
  }
}
