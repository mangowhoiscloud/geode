<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Autoresearch &middot; GEODE Self-Improving Hub</title>
<meta name="description" content="Autoresearch closed-loop landing — current baseline status, generation timeline, and 4 sub-view links (baseline / mutations / results / policies).">
<link rel="stylesheet" href="/geode/self-improving/assets/hub.css">
</head>
<body>

<div class="shell">

  <aside class="sidebar">
    <nav aria-label="Hub navigation">
      <div class="brand">GEODE</div>
      <div class="brand-sub">/self-improving</div>

      <div class="nav-section">Hub</div>
      <ul class="nav-list">
        <li><a href="/geode/self-improving/">Overview</a></li>
      </ul>

      <div class="nav-section">Petri Audit <span class="count">{{ petri_count }}</span></div>
      <ul class="nav-list">
        <li><a href="/geode/self-improving/petri-bundle/">SPA log viewer &#x2197;</a></li>
        <li><a href="/geode/self-improving/petri-bundle/">Recent audits</a>
          <ul class="sub-nav">
{{ sidebar_petri_recent }}
          </ul>
        </li>
      </ul>

      <div class="nav-section">Seed Generation <span class="count">{{ seedgen_count_label }}</span></div>
      <ul class="nav-list">
        <li><a href="/geode/self-improving/seed-generation/">All runs</a>
          <ul class="sub-nav">
{{ sidebar_seedgen_runs }}
          </ul>
        </li>
        <li><a href="/geode/docs/petri/seeds">Run dashboard &#x2197;</a></li>
      </ul>

      <div class="nav-section">Autoresearch <span class="count">{{ autoresearch_status_label }}</span></div>
      <ul class="nav-list">
        <li><a href="/geode/self-improving/autoresearch/" class="active" aria-current="page">Overview</a></li>
        <li><a href="/geode/self-improving/autoresearch/baseline/">Baseline</a></li>
        <li><a href="/geode/self-improving/autoresearch/mutations/">Mutations</a></li>
        <li><a href="/geode/self-improving/autoresearch/results/">Results</a></li>
        <li><a href="/geode/self-improving/autoresearch/policies/">Policies</a></li>
      </ul>

      <div class="nav-section">Docs</div>
      <ul class="nav-list">
        <li><a href="/geode/docs/petri/overview">Petri overview</a></li>
        <li><a href="/geode/docs/petri/run">Run an audit</a></li>
        <li><a href="/geode/docs/petri/judge-dimensions">Judge dimensions</a></li>
      </ul>

      <div class="nav-section">Meta</div>
      <ul class="nav-list">
        <li><a href="https://github.com/mangowhoiscloud/geode" rel="noopener">GitHub &#x2197;</a></li>
      </ul>
    </nav>
  </aside>

  <main class="content">
    <h1 class="page-title">Autoresearch <span class="bucket autoresearch">autoresearch</span></h1>
    <p class="page-sub">Closed-loop self-improvement surface. Reads <code>autoresearch/state/</code> (baseline, mutations ledger, results table, 14 policy SoT files) and links to 4 sub-views. The status block below summarises the current promoted baseline; the generation timeline shows the recent promote history.</p>

{{ stale_baseline_warning }}

    <h2 class="section"><span>Status &middot; current baseline</span></h2>
    <dl class="status-grid">
{{ status_grid_rows }}
    </dl>

    <h2 class="section"><span>Generation timeline &middot; {{ timeline_section_label }}</span></h2>
    <table class="records">
      <thead>
        <tr>
          <th scope="col">gen_tag</th>
          <th scope="col">ts</th>
          <th scope="col">fitness</th>
          <th scope="col">&Delta; fitness</th>
          <th scope="col">mutation target</th>
        </tr>
      </thead>
      <tbody>
{{ timeline_rows }}
      </tbody>
    </table>

    <h2 class="section"><span>Sub-views &middot; 4 autoresearch sub-pages</span></h2>
    <table class="records">
      <thead>
        <tr>
          <th scope="col">sub-page</th>
          <th scope="col">rows</th>
          <th scope="col">last write</th>
          <th scope="col">link</th>
        </tr>
      </thead>
      <tbody>
{{ subview_rows }}
      </tbody>
    </table>

    <div class="build-info">
      <p>Source: <code>autoresearch/state/baseline.json</code>, <code>baseline_archive.jsonl</code>, <code>mutations.jsonl</code>, <code>results.tsv</code>, <code>policies/*.json</code>.</p>
      <p>Published by <code>.github/workflows/pages.yml</code> on every <code>main</code> push.</p>
      <p>Repo: <a href="https://github.com/mangowhoiscloud/geode" rel="noopener">github.com/mangowhoiscloud/geode</a></p>
      <p>Harness chip legend:
        <span class="chip payg">PAYG</span>API key billing &middot;
        <span class="chip claude">Claude Code</span>Max OAuth &middot;
        <span class="chip codex">Codex</span>ChatGPT OAuth &middot;
        <span class="chip geode">GEODE</span>self-target wrapper.
      </p>
      <p class="version-stamp">
        Rendered against GEODE <code>v{{ geode_version }}</code> &middot; DESIGN.md schema {{ design_schema_version }} &middot; built {{ build_date }}.
        Dim subset: 22 (geode_5axes). Pipeline phases: 8. Baseline schema: v2 (PR-2).
      </p>
    </div>
  </main>

</div>
</body>
</html>
