# === Core (at least one LLM key required) ===
# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# ZhipuAI API key — Format: id.secret
# Get yours at https://open.bigmodel.cn/usercenter/apikeys
ZAI_API_KEY=
# Primary LLM model — see /model for options
GEODE_MODEL=claude-opus-4-6
GEODE_VERBOSE=false

# === Observability (optional) ===
# Built-in hook events, RunLog, diagnostics, and usage JSONL are enabled by default.
# Optional OTLP export requires `uv sync --extra obs`.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# TRACELOOP_BASE_URL=http://localhost:4318

# === MCP: Gaming (optional) ===
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# STEAM_API_KEY=

# === MCP: Search (optional) ===
# BRAVE_API_KEY=
# TAVILY_API_KEY=
# EXA_API_KEY=

# === MCP: Social (optional) ===
# YOUTUBE_API_KEY=
# GOOGLE_API_KEY=
# GITHUB_PERSONAL_ACCESS_TOKEN=
# DISCORD_BOT_TOKEN=

# === MCP: Agent Infra (optional) ===
# E2B_API_KEY=

# === Gateway (optional, for Slack/Discord/Telegram) ===
# SLACK_BOT_TOKEN=
# SLACK_BOT_USER_ID=
# TELEGRAM_BOT_TOKEN=

# === autoresearch outer-loop (optional) ===
# Path to a JSON file with `dict[str, str]` of system-prompt sections.
# PromptAssembler Phase 0 reads this and replaces the base system prompt
# with the concatenated section values. autoresearch/train.py writes the
# file from WRAPPER_PROMPT_SECTIONS before invoking `geode audit`, so
# the outer-loop's mutations actually reach the runtime. Unset = baseline.
# GEODE_WRAPPER_OVERRIDE=
