# === Core (at least one LLM key required) ===
# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# ZhipuAI API key — Format: id.secret
# Get yours at https://open.bigmodel.cn/usercenter/apikeys
ZAI_API_KEY=
# Primary LLM model — see /model for options
GEODE_MODEL=claude-opus-4-6
GEODE_VERBOSE=false

# === Tracing (optional) ===
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=geode

# === MCP: Gaming (optional) ===
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# STEAM_API_KEY=

# === MCP: Search (optional) ===
# BRAVE_API_KEY=
# TAVILY_API_KEY=
# EXA_API_KEY=

# === MCP: Social (optional) ===
# YOUTUBE_API_KEY=
# GOOGLE_API_KEY=
# GITHUB_PERSONAL_ACCESS_TOKEN=
# DISCORD_BOT_TOKEN=

# === MCP: Agent Infra (optional) ===
# E2B_API_KEY=

# === Gateway (optional, for Slack/Discord/Telegram) ===
# SLACK_BOT_TOKEN=
# SLACK_BOT_USER_ID=
# TELEGRAM_BOT_TOKEN=
