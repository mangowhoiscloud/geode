# === Core ===
# At least one LLM credential is required. Two ways to provide one:
#   1. Subscription login (recommended) — run `geode` and choose the
#      subscription path (ChatGPT / Codex OAuth). No key needed here.
#   2. API key — uncomment ONE key below. Prefer the GLOBAL ~/.geode/.env,
#      which is authoritative across all projects; a blank key is ignored,
#      so leaving these commented lets the global value win.
# Anthropic — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=
# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# ZhipuAI (format id.secret) — https://open.bigmodel.cn/usercenter/apikeys
# ZAI_API_KEY=
# Primary model — see /model. Unset = default chain (global > routing).
# GEODE_MODEL=claude-opus-4-8
GEODE_VERBOSE=false

# === Observability (optional) ===
# Built-in hook events, RunLog, diagnostics, and usage JSONL are enabled by default.
# Optional OTLP export requires `uv sync --extra obs`.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# TRACELOOP_BASE_URL=http://localhost:4318

# === MCP: Gaming (optional) ===
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# STEAM_API_KEY=

# === MCP: Search (optional) ===
# BRAVE_API_KEY=
# TAVILY_API_KEY=
# EXA_API_KEY=

# === MCP: Social (optional) ===
# YOUTUBE_API_KEY=
# GOOGLE_API_KEY=
# GITHUB_PERSONAL_ACCESS_TOKEN=
# DISCORD_BOT_TOKEN=

# === MCP: Agent Infra (optional) ===
# E2B_API_KEY=

# === Benchmark harnesses: MCPMark (optional, local only) ===
# MCPMark reads `.mcp_env` from the harness working directory. Keep real values
# in an ignored `.mcp_env` and copy/symlink it into
# `artifacts/eval/harnesses/mcpmark/.mcp_env` before live runs.
# SOURCE_NOTION_API_KEY=
# EVAL_NOTION_API_KEY=
# SOURCE_PARENT_PAGE_TITLE=GEODE MCPMark Sandbox
# SOURCE_PARENT_PAGE_URL=https://www.notion.so/GEODE-MCPMark-Sandbox-392581eae2fc80db80f6edef25672615?source=copy_link
# SOURCE_PARENT_PAGE_ID=392581eae2fc80db80f6edef25672615
# EVAL_PARENT_PAGE_TITLE=GEODE MCPMark Eval
# EVAL_PARENT_PAGE_URL=https://www.notion.so/GEODE-MCPMark-Eval-393581eae2fc8067b870f2220047cb3c?source=copy_link
# EVAL_PARENT_PAGE_ID=393581eae2fc8067b870f2220047cb3c
# PLAYWRIGHT_BROWSER=chromium
# PLAYWRIGHT_HEADLESS=True
# GITHUB_TOKENS=
# GITHUB_EVAL_ORG=
# DATABASE_URI=postgresql://mcpmark:mcpmark@127.0.0.1:54329/mcpmark

# === Gateway (optional, for Slack/Discord/Telegram) ===
# Slack: create BOTH tokens from the same app. The xapp token needs the
# connections:write app-level scope. Turn on Socket Mode and Event
# Subscriptions, then subscribe to app_mention and message.channels.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_BOT_USER_ID=
# SLACK_TEAM_ID=
# GEODE_GATEWAY_ENABLED=true
# Remote desktop control from a messaging channel is fail-closed. Prefer
# `[gateway] allow_computer_use = true` in config.toml when deliberately
# enabling it; every sender admitted by a binding can request desktop actions.
# GEODE_GATEWAY_ALLOW_COMPUTER_USE=false
# TELEGRAM_BOT_TOKEN=

# === autoresearch outer-loop (optional) ===
# Path to a JSON file with `dict[str, str]` of system-prompt sections.
# PromptAssembler Phase 0 reads this and replaces the base system prompt
# with the concatenated section values. autoresearch/train.py writes the
# file from WRAPPER_PROMPT_SECTIONS before invoking `geode audit`, so
# the outer-loop's mutations actually reach the runtime. Unset = baseline.
# GEODE_WRAPPER_OVERRIDE=
