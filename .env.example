# === Core (at least one LLM key required) ===
# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# ZhipuAI API key — Format: id.secret (e.g. abc12345.def67890)
# Get yours at https://open.bigmodel.cn/usercenter/apikeys
ZAI_API_KEY=...
# Primary LLM model — see /model for options
GEODE_MODEL=claude-opus-4-6
GEODE_VERBOSE=false

# === Tracing ===
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=geode

# === MCP: Gaming (Priority 1) ===
TWITCH_CLIENT_ID=...
TWITCH_CLIENT_SECRET=...
# STEAM_API_KEY=...          # steam-reviews (optional, public API)

# === MCP: Search (Priority 1) ===
BRAVE_API_KEY=BSA...
TAVILY_API_KEY=tvly-...
EXA_API_KEY=...

# === MCP: Social (Priority 1) ===
YOUTUBE_API_KEY=AIza...
GOOGLE_API_KEY=AIza...
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...
DISCORD_BOT_TOKEN=...

# === MCP: Agent Infra (Priority 2) ===
E2B_API_KEY=e2b_...
# WIKIDATA — no key needed
# PLAYWRIGHT — no key needed

# === MCP: Optional (Priority 3) ===
# FIRECRAWL_API_KEY=fc-...
# NOTION_API_KEY=secret_...
# SENTRY_AUTH_TOKEN=sntrys_...
# SLACK_BOT_TOKEN=xoxb-...
# PINECONE_API_KEY=...
# QDRANT_URL=https://...
# ZEP_API_KEY=...
